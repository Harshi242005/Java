import java.util.*;

class Solution {
    public int findMaximizedCapital(int k, int w, int[] profits, int[] capital) {
        int n = profits.length;
        // Combine projects into a 2D array [capital, profit]
        int[][] projects = new int[n][2];
        for (int i = 0; i < n; i++) {
            projects[i][0] = capital[i];
            projects[i][1] = profits[i];
        }

        // 1. Sort projects by required capital (ascending)
        Arrays.sort(projects, (a, b) -> Integer.compare(a[0], b[0]));

        // 2. Max-heap to store profits of affordable projects
        PriorityQueue<Integer> maxProfitHeap = new PriorityQueue<>(Collections.reverseOrder());

        int projectIdx = 0;
        // At most k projects
        for (int i = 0; i < k; i++) {
            // Add all projects we can now afford to the max-heap
            while (projectIdx < n && projects[projectIdx][0] <= w) {
                maxProfitHeap.add(projects[projectIdx][1]);
                projectIdx++;
            }

            // If no more projects can be afforded, stop early
            if (maxProfitHeap.isEmpty()) {
                break;
            }

            // Pick the most profitable project
            w += maxProfitHeap.poll();
        }

        return w;
    }
}
