import java.util.*;

public class test {
    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        Deque<Integer> deque = new ArrayDeque<Integer>();
        HashMap<Integer, Integer> map = new HashMap<Integer, Integer>();
        
        int n = in.nextInt();
        int m = in.nextInt();
        int maxUnique = 0;

        for (int i = 0; i < n; i++) {
            int num = in.nextInt();
            
            // Add current number to window
            deque.add(num);
            
            // Manual getOrDefault for Java 7
            Integer currentFreq = map.get(num);
            if (currentFreq == null) {
                map.put(num, 1);
            } else {
                map.put(num, currentFreq + 1);
            }

            if (deque.size() == m) {
                // Update max
                if (map.size() > maxUnique) {
                    maxUnique = map.size();
                }
                
                // Early exit if we hit max possible unique elements
                if (maxUnique == m) break;

                // Slide window: remove the oldest element
                int first = deque.remove();
                int count = map.get(first);
                
                if (count == 1) {
                    map.remove(first);
                } else {
                    map.put(first, count - 1);
                }
            }
        }
        System.out.println(maxUnique);
        in.close();
    }
}
