import java.util.*;

class Solution {
    public boolean canCross(int[] stones) {
        // Map: Stone Position -> Set of jump distances (k) that reached it
        Map<Integer, Set<Integer>> map = new HashMap<>();
        for (int stone : stones) {
            map.put(stone, new HashSet<>());
        }
        
        // Initial state: frog is at stone 0 and "jumped" 0 to get there
        map.get(0).add(0);
        
        for (int i = 0; i < stones.length; i++) {
            int currentStone = stones[i];
            for (int k : map.get(currentStone)) {
                // Try jump sizes k-1, k, and k+1
                for (int step = k - 1; step <= k + 1; step++) {
                    if (step > 0 && map.containsKey(currentStone + step)) {
                        map.get(currentStone + step).add(step);
                    }
                }
            }
        }
        
        // If the last stone's set isn't empty, we reached it
        return !map.get(stones[stones.length - 1]).isEmpty();
    }
}
