import java.util.Scanner;

public class Solution {

       static boolean isAnagram(String a, String b) {
        // Step 1: Handle case-insensitivity
        a = a.toLowerCase();
        b = b.toLowerCase();
        
        // Step 2: Length check
        if (a.length() != b.length()) {
            return false;
        }
        
        // Step 3: Frequency check (26 letters in the alphabet)
        int[] frequencies = new int[26];
        
        for (int i = 0; i < a.length(); i++) {
            // Increment count for string a, decrement for string b
            frequencies[a.charAt(i) - 'a']++;
            frequencies[b.charAt(i) - 'a']--;
        }
        
        // Step 4: If anagrams, all values in array must be zero
        for (int count : frequencies) {
            if (count != 0) {
                return false;
            }
        }
        
        return true;
    }
    public static void main(String[] args) {
    
        Scanner scan = new Scanner(System.in);
        String a = scan.next();
        String b = scan.next();
        scan.close();
        boolean ret = isAnagram(a, b);
        System.out.println( (ret) ? "Anagrams" : "Not Anagrams" );
    }
}
